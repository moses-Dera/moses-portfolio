generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String
  coverImage  String?
  repoUrl     String?
  liveUrl     String?
  techStack   String // Stored as comma-separated string for SQLite simplicity
  content     String // The full case study markdown/text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Experience {
  id          String   @id @default(cuid())
  company     String
  role        String
  startDate   String
  endDate     String?
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Skill {
  id          String   @id @default(cuid())
  category    String   // e.g. "System Architecture & Backend Engineering"
  description String   // Descriptive paragraph
  techStack   String   // Comma-separated list of technologies
  order       Int      // For the "01", "02" sequence display
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
